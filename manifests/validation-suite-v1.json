  },
  "validation_dimensions": [
    "fixture classification",
    "state-transition legality",
    "evidence presence",
    "provenance completeness",
    "consent gates",
    "correction bounds",
    "correction authorization",
    "expected-outcome determinism",
    "locked-equation transcription presence"
